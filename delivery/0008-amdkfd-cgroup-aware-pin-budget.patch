diff --git a/drivers/gpu/drm/amd/amdgpu/amdgpu_amdkfd_gpuvm.c b/drivers/gpu/drm/amd/amdgpu/amdgpu_amdkfd_gpuvm.c
--- a/drivers/gpu/drm/amd/amdgpu/amdgpu_amdkfd_gpuvm.c
+++ b/drivers/gpu/drm/amd/amdgpu/amdgpu_amdkfd_gpuvm.c
@@ -1581,12 +1581,40 @@ static bool amdgpu_kfd_rdma_quota_try_charge(struct amdgpu_device *adev,
 					    u64 bytes, u64 *new_total)
 {
 	u64 limit = (u64)dmabuf_pin_max_mb << 20;
+	struct kfd_process *p = NULL;
+
+	/*
+	 * K-5: per-process cap precheck (cgroup-derived OR
+	 * 95% of dmabuf_pin_max_mb when no cgroup). Runs ahead
+	 * of the per-GPU cap so we can reject early with an
+	 * accurate diagnostic.
+	 */
+	if (current && current->mm) {
+		p = kfd_lookup_process_by_mm(current->mm);
+		if (p) {
+			u64 proc_cap = kfd_process_pin_cap_bytes(p, false);
+			u64 proc_cur = atomic64_read(&p->rdma_pinned_bytes);
+			if (proc_cur + bytes > proc_cap) {
+				dev_warn_ratelimited(adev->dev,
+					"K5 reject pid=%d cur=%lluMB + new=%lluMB > cap=%lluMB\n",
+					p->lead_thread ? p->lead_thread->pid : -1,
+					proc_cur >> 20, bytes >> 20,
+					proc_cap >> 20);
+				kfd_unref_process(p);
+				return false;
+			}
+		}
+	}

 	if (!dmabuf_pin_max_mb)
-		return true;
+		goto skip_dev_charge;

 	for (;;) {
 		s64 old_s = atomic64_read(&adev->kfd.rdma_pinned_bytes);
 		s64 new_s;
@@ -1604,16 +1632,32 @@ static bool amdgpu_kfd_rdma_quota_try_charge(struct amdgpu_device *adev,
 		new_s = old_s + (s64)bytes;

 		if ((u64)new_s > limit) {
+			if (p) kfd_unref_process(p);
 			return false;
 		}

 		if (atomic64_cmpxchg(&adev->kfd.rdma_pinned_bytes,
 				     old_s, new_s) == old_s) {
 			*new_total = (u64)new_s;
-			return true;
+			break;
 		}
 	}
+
+skip_dev_charge:
+	/* commit per-process counter on success (K-5) */
+	if (p) {
+		atomic64_add(bytes, &p->rdma_pinned_bytes);
+		kfd_unref_process(p);
+	}
+	return true;
 }

@@ -1825,7 +1869,12 @@ int amdgpu_amdkfd_gpuvm_unpin_bo(struct amdgpu_device *adev,
 		dev_warn_ratelimited(adev->dev,
 			"kfd_unpin RDMA quota count underflow ...");
 	}
 	kgd_mem->rdma_quota_charged = false;
+
+	/* K-5: drop per-process counter symmetrically */
+	if (current && current->mm) {
+		struct kfd_process *p = kfd_lookup_process_by_mm(current->mm);
+		if (p) {
+			atomic64_sub_return(bo_size, &p->rdma_pinned_bytes);
+			kfd_unref_process(p);
+		}
+	}

 	amdgpu_kfd_pin_watermark_check(adev, atomic64_read(&adev->kfd.rdma_pinned_bytes));
 	return 0;

