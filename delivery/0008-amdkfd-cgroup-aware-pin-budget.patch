+    "K-5: percent of cgroup memory.max usable per process for RDMA pin (default 75)");
+
+uint amdgpu_dmabuf_pin_default_ratio_pct = 95;
+module_param_named(dmabuf_pin_default_ratio_pct,
+                   amdgpu_dmabuf_pin_default_ratio_pct, uint, 0644);
+MODULE_PARM_DESC(dmabuf_pin_default_ratio_pct,
+    "K-5: percent of dmabuf_pin_max_mb per process when no cgroup limit (default 95)");
+
+/*
+ * K-5: NOTE the cgroup branch is intentionally NOT clamped by
+ * dmabuf_pin_max_mb. A 32 GiB cgroup pod gets 24 GiB per-proc cap
+ * even on the V17.4.1 default dmabuf_pin_max_mb=4096. Cumulative
+ * defense across processes is the existing per-GPU counter.
+ */
+
 /*
  * V17.4.1 hard ceiling per GPU (UNCHANGED). Acts as the cumulative
  * cap across all processes; the K-5 per-process cap is layered on top.
@@ -2400,6 +2420,16 @@ static const struct file_operations amdgpu_driver_kms_fops = {
 #endif
 };

+/* K-5 host-pin variants (mirror the device side, but smaller default
+ * ratios because libc / page cache also need RAM). */
+uint amdgpu_kfd_host_pin_cgroup_ratio_pct = 50;
+module_param_named(kfd_host_pin_cgroup_ratio_pct,
+                   amdgpu_kfd_host_pin_cgroup_ratio_pct, uint, 0644);
+
+uint amdgpu_kfd_host_pin_default_ratio_pct = 75;
+module_param_named(kfd_host_pin_default_ratio_pct,
+                   amdgpu_kfd_host_pin_default_ratio_pct, uint, 0644);
+
