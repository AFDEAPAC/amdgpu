diff --git a/drivers/gpu/drm/amd/amdkfd/kfd_process_pin_cap.c b/drivers/gpu/drm/amd/amdkfd/kfd_process_pin_cap.c
new file mode 100644
--- /dev/null
+++ b/drivers/gpu/drm/amd/amdkfd/kfd_process_pin_cap.c
@@ -0,0 +1,117 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * KFD per-process pin cap (K-5)
+ *
+ * Compute the effective per-process RDMA / host pin budget. Two
+ * branches, no clamps, no fallback constants:
+ *
+ *   in real cgroup  -> memcg.max * cgroup_ratio_pct / 100
+ *   no/root cgroup  -> dmabuf_pin_max_mb * default_ratio_pct / 100
+ *
+ * Cached for 1 second to avoid hammering memcg on every pin.
+ */
+
+#include <linux/kernel.h>
+#include <linux/sched.h>
+#include <linux/seqlock.h>
+#include <linux/ktime.h>
+#include <linux/cgroup.h>
+#include <linux/memcontrol.h>
+#include "kfd_priv.h"
+#include "kcl_memcg.h"
+
+/* extern module params from amdgpu_drv.c */
+extern uint amdgpu_dmabuf_pin_cgroup_ratio_pct;
+extern uint amdgpu_dmabuf_pin_default_ratio_pct;
+extern uint amdgpu_kfd_host_pin_cgroup_ratio_pct;
+extern uint amdgpu_kfd_host_pin_default_ratio_pct;
+/* dmabuf_pin_max_mb is the existing module param */
+
+#define K5_CACHE_TTL_NS    (1ULL * NSEC_PER_SEC)
+
+void kfd_process_pin_cap_init(struct kfd_process *p)
+{
+	seqlock_init(&p->pin_cap_lock);
+	p->rdma_pin_cap_bytes  = 0;
+	p->host_pin_cap_bytes  = 0;
+	p->pin_cap_observed_at = ktime_set(0, 0);
+}
+
+void kfd_process_pin_cap_destroy(struct kfd_process *p)
+{
+	/* counters are atomics; nothing to free here. Drain back to
+	 * per-GPU happens through normal unpin path during process exit.
+	 */
+}
+
+static u64 kfd_process_pin_cap_recompute(struct kfd_process *p, bool host)
+{
+	u64 sys_cap_bytes      = (u64)dmabuf_pin_max_mb << 20;
+	u64 ratio_in_cgroup    = host ? amdgpu_kfd_host_pin_cgroup_ratio_pct
+	                              : amdgpu_dmabuf_pin_cgroup_ratio_pct;
+	u64 ratio_no_cgroup    = host ? amdgpu_kfd_host_pin_default_ratio_pct
+	                              : amdgpu_dmabuf_pin_default_ratio_pct;
+	u64 cap;
+#ifdef CONFIG_MEMCG
+	struct mem_cgroup *memcg = NULL;
+	struct task_struct *task;
+
+	rcu_read_lock();
+	task = p->lead_thread;
+	if (task)
+		memcg = amdkcl_mem_cgroup_from_task(task);
+	if (memcg && !amdkcl_memcg_is_root(memcg)) {
+		u64 memcg_max = amdkcl_memcg_memory_max(memcg);
+		/*
+		 * cgroup-v1 stores "no limit" as PAGE_COUNTER_MAX
+		 *   = (LONG_MAX / PAGE_SIZE) * PAGE_SIZE
+		 * which on 4 KiB pages is 0x7FFF_FFFF_FFFF_F000 (just below
+		 * LONG_MAX). A plain `< LONG_MAX` check misclassifies that as
+		 * "in cgroup with absurdly large limit" and computes a 6 EiB
+		 * cap. Use a generous 1 EiB threshold instead so any real
+		 * container limit is honored and any sentinel falls to the
+		 * no-cgroup branch.
+		 *
+		 * Confirmed empirically on hjbog-srdc-22 (5.10 kernel,
+		 * cgroup-v1): bare-metal user session has memcg.max ==
+		 * 0x7FFF_FFFF_FFFF_F000 = LONG_MAX - 4095.
+		 */
+		if (memcg_max < (1ULL << 60)) {
+			cap = memcg_max * ratio_in_cgroup / 100ULL;
+			rcu_read_unlock();
+			goto store;
+		}
+	}
+	rcu_read_unlock();
+#endif
+
+	/* root cgroup / no CONFIG_MEMCG / unlimited memcg
+	 * -> 0.95 of the static system cap, no separate constant
+	 */
+	cap = sys_cap_bytes * ratio_no_cgroup / 100ULL;
+
+store:
+	write_seqlock(&p->pin_cap_lock);
+	if (host)
+		p->host_pin_cap_bytes = cap;
+	else
+		p->rdma_pin_cap_bytes = cap;
+	p->pin_cap_observed_at = ktime_get();
+	write_sequnlock(&p->pin_cap_lock);
+
+	return cap;
+}
+
+u64 kfd_process_pin_cap_bytes(struct kfd_process *p, bool host)
+{
+	u64 cached;
+	unsigned int seq;
+	ktime_t observed;
+
+	if (!p)
+		return ULLONG_MAX;
+
+	do {
+		seq = read_seqbegin(&p->pin_cap_lock);
+		observed = p->pin_cap_observed_at;
+		cached = host ? p->host_pin_cap_bytes : p->rdma_pin_cap_bytes;
+	} while (read_seqretry(&p->pin_cap_lock, seq));
+
+	if (cached &&
+	    ktime_before(ktime_get(),
+	                 ktime_add_ns(observed, K5_CACHE_TTL_NS)))
+		return cached;
+
+	return kfd_process_pin_cap_recompute(p, host);
+}

diff --git a/drivers/gpu/drm/amd/amdkcl/kcl_memcg.c b/drivers/gpu/drm/amd/amdkcl/kcl_memcg.c
new file mode 100644
--- /dev/null
+++ b/drivers/gpu/drm/amd/amdkcl/kcl_memcg.c
@@ -0,0 +1,73 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * amdkcl shim for memory cgroup APIs needed by K-5 cgroup-aware pin
+ * budget. Smooths over kernel-version differences and (when the
+ * upstream symbol is not exported) provides a kallsyms-based fallback.
+ */
+
+#include <linux/version.h>
+#include <linux/kallsyms.h>
+#include <linux/memcontrol.h>
+#include <linux/page_counter.h>
+#include "kcl_memcg.h"
+
+#if defined(CONFIG_MEMCG)
+
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(5, 4, 0) && defined(KCL_MEMCG_FROM_TASK_EXPORTED)
+
+struct mem_cgroup *amdkcl_mem_cgroup_from_task(struct task_struct *t)
+{
+	return mem_cgroup_from_task(t);
+}
+
+#else  /* fallback via kallsyms_lookup_name (Linux <5.7 ok) */
+
+static struct mem_cgroup *(*p_mem_cgroup_from_task)(struct task_struct *) =
+	(void *)KALLSYMS_LOOKUP("mem_cgroup_from_task");
+
+struct mem_cgroup *amdkcl_mem_cgroup_from_task(struct task_struct *t)
+{
+	if (!p_mem_cgroup_from_task)
+		return NULL;
+	return p_mem_cgroup_from_task(t);
+}
+
+#endif
+EXPORT_SYMBOL_GPL(amdkcl_mem_cgroup_from_task);
+
+u64 amdkcl_memcg_memory_max(struct mem_cgroup *memcg)
+{
+	if (!memcg)
+		return ULLONG_MAX;
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(5, 5, 0)
+	/* page_counter.max is in pages; convert to bytes */
+	return (u64)READ_ONCE(memcg->memory.max) << PAGE_SHIFT;
+#else
+	/* older kernels: page_counter.limit, same units */
+	return (u64)READ_ONCE(memcg->memory.limit) << PAGE_SHIFT;
+#endif
+}
+EXPORT_SYMBOL_GPL(amdkcl_memcg_memory_max);
+
+bool amdkcl_memcg_is_root(struct mem_cgroup *memcg)
+{
+	return mem_cgroup_is_root(memcg);
+}
+EXPORT_SYMBOL_GPL(amdkcl_memcg_is_root);
+
+#else  /* !CONFIG_MEMCG */
+
+struct mem_cgroup *amdkcl_mem_cgroup_from_task(struct task_struct *t)
+{
+	return NULL;
+}
+u64 amdkcl_memcg_memory_max(struct mem_cgroup *memcg)
+{
+	return ULLONG_MAX;
+}
+bool amdkcl_memcg_is_root(struct mem_cgroup *memcg) { return true; }
+EXPORT_SYMBOL_GPL(amdkcl_mem_cgroup_from_task);
+EXPORT_SYMBOL_GPL(amdkcl_memcg_memory_max);
+EXPORT_SYMBOL_GPL(amdkcl_memcg_is_root);
+
+#endif

