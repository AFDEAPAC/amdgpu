+++ b/drivers/gpu/drm/amd/amdgpu/amdgpu_drv.c
@@ -200,6 +200,26 @@ uint amdgpu_dmabuf_pin_critical_mb;
 module_param_named(dmabuf_pin_critical_mb, amdgpu_dmabuf_pin_critical_mb, uint, 0644);
 MODULE_PARM_DESC(dmabuf_pin_critical_mb, "RDMA pin critical level (default: 90% of max)");

+/* K-5: cgroup-aware pin budget (2 knobs only) */
